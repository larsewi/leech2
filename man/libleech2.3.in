.TH LIBLEECH2 3 "@DATE@" "leech2 @VERSION@" "Library Functions"
.SH NAME
libleech2 \- C API for tracking CSV changes and producing SQL patches
.SH SYNOPSIS
.B #include <leech2.h>
.PP
.BI "int lch_log_init(lch_log_callback_t " callback ", void *" usr_data );
.PP
.BI "lch_config_t *lch_init(const char *" work_dir );
.br
.BI "void lch_deinit(lch_config_t *" cfg );
.PP
.BI "int lch_block_create(const lch_config_t *" cfg );
.PP
.BI "int lch_patch_create(const lch_config_t *" cfg ", const char *" hash ", lch_buffer_t *" out );
.br
.BI "int lch_patch_to_sql(const lch_config_t *" cfg ", const lch_buffer_t *" patch ", char **" sql );
.br
.BI "int lch_patch_inject(const lch_config_t *" cfg ", const lch_buffer_t *" in ", const char *" name ", const lch_cell_t *" cell ", lch_buffer_t *" out );
.br
.BI "int lch_patch_applied(const lch_config_t *" cfg ", const lch_buffer_t *" patch );
.br
.BI "int lch_patch_failed(const lch_config_t *" cfg );
.PP
.BI "void lch_buffer_free(lch_buffer_t *" buf );
.br
.BI "void lch_sql_free(char *" sql );
.SH DESCRIPTION
.B libleech2
is a C-compatible shared library for tracking CSV table changes using a git-like
content-addressable block chain. It computes deltas between table snapshots,
stores them as linked blocks, and produces consolidated patches that convert
into SQL statements for replaying changes on a target database.
.PP
The library operates on a work directory containing a configuration file
.RB ( config.toml
or
.BR config.json )
that defines tables, field schemas, filters, and other settings. See
.BR lch (1)
for configuration details.
.SH FUNCTIONS
.SS Logging
.TP
.BI "int lch_log_init(lch_log_callback_t " callback ", void *" usr_data )
Install a custom logger that delivers all log messages through
.IR callback .
Must be called before
.BR lch_init ()
for the callback to receive messages from initialization. May be called again
to atomically replace
.I callback
and
.IR usr_data ;
after a replacement the previous callback is no longer invoked, and the library
does not free the previous
.IR usr_data ,
so the caller owns its lifetime. Safe to call concurrently from multiple
threads. Once installed,
.I callback
itself may be invoked from any thread, possibly in parallel, so both
.I callback
and
.I usr_data
must be thread-safe.
.I callback
must not be NULL.
.I usr_data
is an opaque pointer forwarded to every callback invocation and must remain
valid until the callback is replaced by a later
.BR lch_log_init ()
call or the process exits. Returns
.B LCH_SUCCESS
on success and
.B LCH_FAILURE
on error.
.SS Lifecycle
.TP
.BI "lch_config_t *lch_init(const char *" work_dir )
Initialize the library by parsing the configuration in
.IR work_dir .
Returns an opaque config handle on success, or NULL on failure. The caller must
eventually free the handle with
.BR lch_deinit ().
.I work_dir
must not be NULL.
.TP
.BI "void lch_deinit(lch_config_t *" cfg )
Free all resources associated with
.IR cfg .
Passing NULL is a safe no-op. After this call the handle is invalid and must not
be used.
.SS Block creation
.TP
.BI "int lch_block_create(const lch_config_t *" cfg )
Read the configured CSV sources, compute the new state and the delta against
the previous state, and write a new block together with updated STATE and HEAD
files. History truncation is performed afterwards.
.SS Patch operations
.TP
.BI "int lch_patch_create(const lch_config_t *" cfg ", const char *" hash ", lch_buffer_t *" out )
Walk the block chain from HEAD back to
.I hash
and produce a consolidated patch. The patch is encoded (protobuf + optional zstd
compression) into the buffer written to
.IR out .
.IP
If
.I hash
is NULL, the REPORTED hash is used as the starting point; if no REPORTED file
exists, genesis (the very beginning of the chain) is used.
.IP
Passing an explicit
.I hash
allows callers to bypass the built-in REPORTED mechanism and implement their own
system for tracking which blocks have been reported.
.IP
The buffer must eventually be freed with
.BR lch_buffer_free ().
.TP
.BI "int lch_patch_to_sql(const lch_config_t *" cfg ", const lch_buffer_t *" patch ", char **" sql )
Decode the patch in
.I patch
and produce SQL statements that apply the patch to a downstream database. Delta
payloads generate DELETE, INSERT, and UPDATE statements. State payloads generate
TRUNCATE followed by INSERT statements. All statements are wrapped in BEGIN /
COMMIT.
.IP
If the patch contains no actionable changes,
.I sql
is set to NULL and the function returns
.BR LCH_SUCCESS .
Otherwise, the string must be freed with
.BR lch_sql_free ().
.TP
.BI "int lch_patch_inject(const lch_config_t *" cfg ", const lch_buffer_t *" in ", const char *" name ", const lch_cell_t *" cell ", lch_buffer_t *" out )
Decode the patch in
.IR in ,
add or overwrite an injected field with the given
.I name
and typed
.IR cell ,
and write a newly encoded patch to
.IR out .
The input buffer is not modified; the caller manages its lifetime independently.
.IP
The
.B kind
tag on
.I cell
controls how the value is formatted as a SQL literal:
.B LCH_VALUE_TEXT
becomes a single-quoted string,
.B LCH_VALUE_NUMBER
is emitted as a numeric literal, and
.B LCH_VALUE_BOOLEAN
is emitted as
.BR TRUE / FALSE .
.B LCH_VALUE_NULL
is not accepted.
.IP
If a field with the same
.I name
is already present on the patch -- whether from static configuration or a
prior injection -- both its value and kind are replaced.
.IP
The buffer written to
.I out
must eventually be freed with
.BR lch_buffer_free ().
.TP
.BI "int lch_patch_applied(const lch_config_t *" cfg ", const lch_buffer_t *" patch )
Mark a patch as applied by updating the REPORTED file with the patch's head
hash. Future truncation uses this to know which blocks are safe to remove.
.TP
.BI "int lch_patch_failed(const lch_config_t *" cfg )
Mark a patch as failed by removing the REPORTED file. The next
.BR lch_patch_create ()
will produce a full state patch (TRUNCATE + INSERT for all tables). Safe to call
regardless of whether a REPORTED file exists.
.SS Memory management
.TP
.BI "void lch_buffer_free(lch_buffer_t *" buf )
Free a library-owned buffer. Passing NULL is a safe no-op, as is passing a
buffer whose
.B data
field is NULL.
.TP
.BI "void lch_sql_free(char *" sql )
Free an SQL string previously returned by
.BR lch_patch_to_sql ().
Passing NULL is a safe no-op.
.SH TYPES
.TP
.B lch_config_t
Opaque configuration handle created by
.BR lch_init ()
and freed by
.BR lch_deinit ().
All API functions require a valid handle.
.TP
.B lch_log_level_t
Log severity levels:
.BR LCH_LOG_ERROR " (1),"
.BR LCH_LOG_WARN " (2),"
.BR LCH_LOG_INFO " (3),"
.BR LCH_LOG_DEBUG " (4),"
.BR LCH_LOG_TRACE " (5)."
Trace messages are only emitted in debug builds; release builds strip them at
compile time.
.TP
.B lch_log_callback_t
Callback function type:
.BI "void (*)(lch_log_level_t " level ", const char *" msg ", void *" usr_data )."
The
.I msg
string is only valid for the duration of the callback invocation.
.TP
.B lch_buffer_t
Owned byte buffer with fields
.BI "uint8_t *" data
and
.BI "size_t " len .
Released with
.BR lch_buffer_free ().
.SH RETURN VALUES
Functions returning
.B int
use the following convention:
.TP
.B LCH_SUCCESS (0)
The operation completed successfully.
.TP
.B LCH_FAILURE (\-1)
An error occurred. If a log callback was installed with
.BR lch_log_init (),
detailed error messages are delivered through it.
.PP
.BR lch_init ()
returns a pointer on success or NULL on failure.
.PP
.BR lch_deinit (),
.BR lch_buffer_free (),
and
.BR lch_sql_free ()
do not return a value.
.SH CONCURRENCY
.B libleech2
serializes concurrent access to its own work-directory state files with
advisory
.BR flock (2)
locks, so multiple processes may share a
.I work_dir
safely.
.PP
The configured CSV source files are external inputs not owned by leech2. To
prevent
.BR lch_block_create ()
from observing a half-written CSV, the producer must guarantee readers only
ever see a complete file. The recommended approach is atomic replacement:
write the new contents to a temporary file in the same directory, then
.BR rename (2)
it over the source path.
.PP
Alternatively, the producer may hold an exclusive
.BR flock (2)
on the CSV while rewriting it in place.
.B libleech2
takes a shared
.BR flock (2)
on each CSV source while reading, so it will wait for such a producer to
finish.
.PP
No additional synchronization is required from FFI callers.
.SH EXAMPLE
.PP
.RS
.nf
#include <stdio.h>
#include <stdlib.h>
#include <leech2.h>

static void log_cb(lch_log_level_t level, const char *msg, void *data) {
    (void)data;
    fprintf(stderr, "[%d] %s\\n", level, msg);
}

int main(void) {
    if (lch_log_init(log_cb, NULL) != LCH_SUCCESS) return EXIT_FAILURE;

    lch_config_t *cfg = lch_init("/path/to/.leech2");
    if (!cfg) return EXIT_FAILURE;

    if (lch_block_create(cfg) != LCH_SUCCESS) {
        lch_deinit(cfg);
        return EXIT_FAILURE;
    }

    lch_buffer_t patch = {0};
    if (lch_patch_create(cfg, NULL, &patch) != LCH_SUCCESS) {
        lch_deinit(cfg);
        return EXIT_FAILURE;
    }

    char *sql;
    if (lch_patch_to_sql(cfg, &patch, &sql) != LCH_SUCCESS) {
        lch_buffer_free(&patch);
        lch_deinit(cfg);
        return EXIT_FAILURE;
    }

    if (sql) {
        printf("%s", sql);
        lch_sql_free(sql);
    }

    /* Mark as applied on success, or failed on error */
    lch_patch_applied(cfg, &patch);
    lch_buffer_free(&patch);

    lch_deinit(cfg);
    return EXIT_SUCCESS;
}
.fi
.RE
.PP
Compile with:
.PP
.RS
.nf
cc -o example example.c -lleech2
.fi
.RE
.SH SEE ALSO
.BR lch (1)
.PP
Full documentation and source code:
.UR https://github.com/larsewi/leech2
.UE
